export type Json =
  | string
  | number
  | boolean
  | null
  | { [key: string]: Json | undefined }
  | Json[]

export type Database = {
  public: {
    Tables: {
      kunden: {
        Row: {
          id: string
          name: string
          unternehmen_id: string | null
        }
      }
      unternehmen: {
        Row: {
          id: string
          company_name: string
        }
      }
    }
  }
}
